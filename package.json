{
  "name": "@cbortech/uuid-extension",
  "version": "0.1.0",
  "description": "UUID application-string extension for @cbortech/cbor",
  "keywords": [
    "cbor",
    "cbor-edn",
    "uuid"
  ],
  "homepage": "https://github.com/cbortech/uuid-extension",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbortech/uuid-extension.git"
  },
  "bugs": {
    "url": "https://github.com/cbortech/uuid-extension/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "author": "Yasuhiro Kudo <ykudo@ykudo.org>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepack": "npm run build",
    "build": "vite build",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "npm run build && npm start",
    "clean": "node -e \"['dist','coverage'].forEach(d=>require('fs').rmSync(d,{recursive:true,force:true}))\"",
    "test": "vitest run",
    "test:node": "vitest run",
    "test:chromium": "cross-env BROWSER=chromium vitest run --config vitest.browser.config.ts",
    "test:firefox": "cross-env BROWSER=firefox vitest run --config vitest.browser.config.ts",
    "test:webkit": "cross-env BROWSER=webkit vitest run --config vitest.browser.config.ts",
    "test:all": "npm run test:node && npm run test:chromium && npm run test:firefox && npm run test:webkit",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "@cbortech/cbor": "^0.24.0"
  },
  "devDependencies": {
    "@cbortech/cbor": "^0.24.0",
    "@types/node": "^24.12.4",
    "@vitest/browser": "^4.1.6",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "cross-env": "^10.1.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.6"
  }
}
